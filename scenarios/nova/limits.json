{
  "NovaServers.list_servers": [
    {
      "runner": {
        "type": "rps",
        "times": 500,
        "rps": 50
      },
      "args": {
        "detailed": true
      },
      "context": {
        "users": {
          "tenants": 3,
          "users_per_tenant": 10
        },
        "servers": {
          "flavor": {
            "name": "m1.tiny"
          },
          "image": {
            "name": "cirros-0.5.2-x86_64-disk"
          },
          "servers_per_tenant": 2
        }
      },
      "sla": {
        "failure_rate": {
          "max": 0
        }
      }
    }
  ]
}
